{
  "name": "SmartMail Assistant",
  "description": "Smart AI-powered assistant for drafting and replying to emails instantly.",
  "version": "1.0",
  "manifest_version": 3,

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://smartmail-backend-p35t.onrender.com/*",
    "*://mail.google.com/*"
  ],

"content_scripts": [
  {
    "matches": ["https://mail.google.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://mail.google.com/*"]
    }
  ],

  "icons": {

    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "SmartMail Assistant"
  }
}